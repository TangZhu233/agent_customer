# ============================================================
# 智能客服 Agent — 环境变量配置模板
# 使用方法：
#   1. 复制本文件为 .env ：  cp .env.example .env
#   2. 填入你的 DeepSeek API Key（见下方获取方式）
#   3. .env 已被 .gitignore 忽略，不会提交到 Git，安全！
# ============================================================

# --- DeepSeek API 配置 ---
# 密钥获取：访问 https://platform.deepseek.com → 注册/登录 → API Keys → 创建新 Key → 复制
DEEPSEEK_API_KEY=sk-your-api-key-here
# API 地址（官方默认，无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 模型名称（flash=快速便宜 / pro=强力推理，客服场景推荐 flash）
DEEPSEEK_MODEL=deepseek-v4-flash

# --- 数据库路径（相对于项目根目录）---
DATABASE_PATH=data/customer.db

# --- 用户认证 ---
# JWT 签名密钥（生产环境务必修改为强随机字符串）
JWT_SECRET_KEY=agent-customer-dev-secret-change-in-production
# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=24

# --- RAG / 向量检索 ---
# 嵌入模型名称（sentence-transformers 模型 ID，中文优化）
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
# ChromaDB 持久化目录（相对于项目根目录）
CHROMA_DB_PATH=data/chroma_db
# 向量检索返回数量（建议 5，值越大覆盖面越广但响应稍慢）
VECTOR_SEARCH_K=5

# --- API 限流 ---
# /chat 接口每分钟每用户最大请求数
RATE_LIMIT_CHAT_PER_USER=30/minute
# /chat 接口每分钟每 IP 最大请求数
RATE_LIMIT_CHAT_PER_IP=60/minute

# --- 对话历史 ---
# 保留最近 N 条消息作为上下文（20 条约 10 轮对话）
MAX_HISTORY_MESSAGES=20
# 字符数安全阈值：prompt 总字符数超过此值时自动从最早消息裁剪
# 默认 80000 字符（约占 DeepSeek 128K 上下文的 30%，留足余量给模型回复和工具调用）
MAX_HISTORY_CHAR_LIMIT=80000

# --- 熔断器 (Circuit Breaker) ---
# 启用熔断保护（连续失败 N 次后快速失败，避免雪崩）
CB_ENABLED=true
# 连续失败次数阈值（触发熔断 CLOSED → OPEN）
CB_FAILURE_THRESHOLD=5
# 熔断后等待多少秒进入 HALF_OPEN 状态
CB_RECOVERY_TIMEOUT=30
# HALF_OPEN 状态下允许的最大探测请求数
CB_HALF_OPEN_MAX=1
# 单次 LLM 调用的超时时间（秒，0=不限制）
LLM_REQUEST_TIMEOUT=30.0

# --- Redis 语义缓存 ---
# 是否启用 Redis 连接（需要先启动 Redis 服务）
REDIS_ENABLED=false
# Redis 连接地址
REDIS_URL=redis://localhost:6379/0
# 缓存有效期（秒，默认 3600 = 1 小时）
REDIS_CACHE_TTL=3600

# --- 多路召回检索 ---
# 检索模式：dense=仅向量(默认,向后兼容) | hybrid=向量+BM25融合
RETRIEVAL_MODE=dense
# 是否启用 LLM 重排序（开启后精度更高但增加一次 API 调用）
RERANK_ENABLED=false
# RRF 融合常数 k（学界标准 k=60）
FUSION_K=60
# 重排序后返回的文档数
RERANK_TOP_K=5
# 每条检索路径的召回数量（融合前拉取更多候选）
MULTI_RECALL_K=10

# --- GitHub Token（用于更新仓库描述等 API 操作，可选）---
# 获取方式：https://github.com/settings/tokens → Generate new token (classic) → 勾选 repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
